#!/usr/bin/env bash
set -euo pipefail

message_file="${1:?commit message file is required}"
first_line="$(head -n 1 "$message_file")"

if [[ ! "$first_line" =~ ^(feat|fix|docs|chore|refactor|test|ops|data|build|ci|perf|style)(\([a-zA-Z0-9._-]+\))?!?:\ .+ ]]; then
  echo "Commit message must use Conventional Commits, e.g. feat: add solver puzzle"
  exit 1
fi
